# PostgreSQL — Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres?pgbouncer=true
DATABASE_URL_UNPOOLED=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase Storage (server-side)
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase Realtime (client-side — safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password
ADMIN_SECRET=your-long-random-secret-string

# WhatsApp
NEXT_PUBLIC_WHATSAPP_NUMBER=17781234567
WHATSAPP_VERIFY_TOKEN=your-random-verify-token
